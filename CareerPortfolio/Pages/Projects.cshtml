@page
@model CareerPortfolio.Pages.ProjectsModel
@{
    ViewData["Title"] = "Projects";
}

<div class="container py-5">
    <h1 class="display-5 fw-bold mb-3">Projects</h1>
    <p class="lead text-muted mb-5">
        These projects reflect what I’m currently building and the direction I’m taking as I continue growing my full-stack development skills.
    </p>

    <div class="row g-4">
        <div class="col-md-6 col-lg-4">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <h2 class="h4 fw-bold">Career Portfolio Website</h2>
                    <p class="text-muted mb-3">Status: In Progress</p>
                    <p>
                        A personal portfolio website built with ASP.NET Core Razor Pages to showcase my experience, technical skills, and professional background.
                    </p>
                    <p class="mb-0">
                        <strong>Tech:</strong> C#, ASP.NET Core, Razor Pages, HTML, CSS, Bootstrap
                    </p>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-lg-4">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <h2 class="h4 fw-bold">Job Application Tracker</h2>
                    <p class="text-muted mb-3">Status: Planned</p>
                    <p>
                        A full-stack application for tracking job applications, interview stages, follow-ups, notes, and outcomes in one place.
                    </p>
                    <p class="mb-0">
                        <strong>Planned Tech:</strong> C#, ASP.NET Core, SQL Server, React
                    </p>
                </div>
            </div>
        </div>

        <div class="col-md-6 col-lg-4">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <h2 class="h4 fw-bold">Audit History Tracker</h2>
                    <p class="text-muted mb-3">Status: Planned</p>
                    <p>
                        A project inspired by real-world work involving change tracking, with a focus on capturing and displaying record updates in a clear and useful way.
                    </p>
                    <p class="mb-0">
                        <strong>Planned Tech:</strong> C#, ASP.NET Core, SQL Server, JSON
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>