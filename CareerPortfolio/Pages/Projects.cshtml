@page
@model CareerPortfolio.Pages.ProjectsModel
@{
    ViewData["Title"] = "Projects";
}

<div class="container py-5">
    <div class="mb-5">
        <h1 class="display-5 fw-bold mb-2">Projects</h1>
        <p class="text-muted">
            These projects reflect what I’m currently building and the direction I’m taking as I continue growing my full-stack development skills.
        </p>
    </div>

    <div class="card shadow-sm mb-5">
        <div class="card-body">
            <h2 class="h4 fw-bold mb-4">Add New Project</h2>

            <form method="post" asp-page-handler="Create">
                <div class="mb-3">
                    <label asp-for="NewProject.Title" class="form-label"></label>
                    <input asp-for="NewProject.Title" class="form-control" />
                    <span asp-validation-for="NewProject.Title" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="NewProject.Description" class="form-label"></label>
                    <textarea asp-for="NewProject.Description" class="form-control" rows="3"></textarea>
                    <span asp-validation-for="NewProject.Description" class="text-danger"></span>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="NewProject.Status" class="form-label"></label>
                        <input asp-for="NewProject.Status" class="form-control" />
                        <span asp-validation-for="NewProject.Status" class="text-danger"></span>
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="NewProject.TechStack" class="form-label"></label>
                        <input asp-for="NewProject.TechStack" class="form-control" />
                        <span asp-validation-for="NewProject.TechStack" class="text-danger"></span>
                    </div>
                </div>

                <div class="row">
                    <div class="col-md-6 mb-3">
                        <label asp-for="NewProject.GitHubUrl" class="form-label"></label>
                        <input asp-for="NewProject.GitHubUrl" class="form-control" />
                    </div>

                    <div class="col-md-6 mb-3">
                        <label asp-for="NewProject.LiveDemoUrl" class="form-label"></label>
                        <input asp-for="NewProject.LiveDemoUrl" class="form-control" />
                    </div>
                </div>

                <div class="mt-3">
                    <button type="submit" class="btn btn-accent">
                        Add Project
                    </button>
                </div>
            </form>
        </div>
    </div>

    <div class="row g-4">
        @foreach (var project in Model.Projects)
        {
            <div class="col-md-6 col-lg-4">
                <div class="card shadow-sm project-card">
                    <div class="card-body">
                        <h2 class="h4 fw-bold">@project.Title</h2>
                        <span class="badge bg-secondary mb-3 align-self-start">
                            @project.Status
                        </span>

                        <p class="mb-2">@project.Description</p>

                        <p class="text-muted small mb-3">
                            <strong>Tech:</strong> @project.TechStack
                        </p>

                        @if (!string.IsNullOrEmpty(project.GitHubUrl))
                        {
                            <a href="@project.GitHubUrl" target="_blank">GitHub</a>
                        }

                        @if (!string.IsNullOrEmpty(project.LiveDemoUrl))
                        {
                            <a href="@project.LiveDemoUrl" target="_blank">Live Demo</a>
                        }

                        <div class="d-flex gap-2 mt-3 project-actions">
                            <a asp-page="/Projects/Edit" asp-route-id="@project.ID" class="btn btn-outline-secondary btn-sm me-2">
                                Edit
                            </a>

                            <form method="post" asp-page-handler="Delete" asp-route-id="@project.ID">
                                <button type="submit" class="btn btn-danger btn-sm">
                                    Delete
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>