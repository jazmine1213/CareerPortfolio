@page
@model CareerPortfolio.Pages.ExperienceModel
@{
    ViewData["Title"] = "Experience";
}

<div class="container py-5">
    <h1 class="display-5 fw-bold mb-3">Experience</h1>
    <p class="lead text-muted mb-5">
        My background includes business application development, production support, reporting, and technical problem-solving across enterprise environments.
    </p>

    @foreach (var experience in Model.ExperienceEntries)
    {
        <div class="card shadow-sm mb-4">
            <div class="card-body">
                <h2 class="h4 fw-bold mb-1">@experience.JobTitle</h2>
                <p class="text-muted mb-3">@experience.Company | @experience.DateRange</p>
                <p class="mb-0">@experience.Description</p>
            </div>
        </div>
    }
</div>